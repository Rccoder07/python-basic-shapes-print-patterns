print("Square")
for i in range(4):
    print("*" * 4)

print("\nRectangle")
for i in range(4):
    print("*" * 6)

print("\nRight Triangle")
for i in range(1, 5):
    print("*" * i)

print("\nInverted Triangle")
for i in range(4, 0, -1):
    print("*" * i)

print("\nPyramid")
for i in range(1, 5):
    print(" " * (4 - i) + "*" * (2 * i - 1))
